#!/usr/bin/make -f

export DH_VERBOSE = 1

%:
	dh $@

override_dh_auto_configure:
	mkdir -p build
	cd build && cmake .. -DCMAKE_BUILD_TYPE=Release

override_dh_auto_build:
	$(MAKE) -C build -j$$(nproc)

override_dh_auto_install:
	install -d debian/tmp/usr/lib/valkey/modules
	install -m 755 build/libvalkeyluajit.so \
		debian/tmp/usr/lib/valkey/modules/

override_dh_auto_test:
	# Tests require Valkey server — skip during package build
	true

override_dh_shlibdeps:
	dh_shlibdeps -l$(CURDIR)/build/
